# Database Configuration
DATABASE_URL=sqlite:///./tracecredit.db
# For production: postgresql://user:password@localhost/tracecredit

# Model Configuration
MODEL_DIR=models
ACTIVE_MODEL_VERSION=v2

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=False

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/tracecredit.log

# Feature Configuration
FEATURE_ENGINEERING_ENABLED=True
BASELINE_MONTH=1

# Drift Detection Configuration
DRIFT_THRESHOLD_PERCENTAGE=20.0
DRIFT_SENSITIVITY=0.05

# Environment
ENVIRONMENT=development
